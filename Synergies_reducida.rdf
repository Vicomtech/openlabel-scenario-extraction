        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#FrameData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <synergies:description>rotation information of the 3D bounding box</synergies:description>
        <rdfs:label>bbox3Drotation</rdfs:label>
    </owl:DatatypeProperty>
    


