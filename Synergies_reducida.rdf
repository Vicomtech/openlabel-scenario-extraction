        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3D"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#FrameData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>X dimension of the 3D bounding box</synergies:description>
        <rdfs:label>bbox3DX</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3DY -->

