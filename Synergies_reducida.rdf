        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Y dimension of the 3D bounding box</synergies:description>
        <rdfs:label>bbox3DY</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3DZ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3DZ">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3D"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#FrameData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Z dimension of the 3D bounding box</synergies:description>
        <rdfs:label>bbox3DZ</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3Drotation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#bbox3Drotation">
