        <rdfs:label>scene_description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#scene_name -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#scene_name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#scene"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
