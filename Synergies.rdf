    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#qX -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#qX">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#EgoData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>Quaternion that transforms from IMU coordinates to a fixed reference frame. The yaw of this reference frame is arbitrary, determined by the IMU. However, the x-y plane of the reference frame is perpendicular to gravity, and z points up.</rdfs:comment>
        <rdfs:label>qX</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#qY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#qY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#EgoData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Quaternion that transforms from IMU coordinates to a fixed reference frame. The yaw of this reference frame is arbitrary, determined by the IMU. However, the x-y plane of the reference frame is perpendicular to gravity, and z points up.</synergies:description>
        <rdfs:label>qY</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#qZ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#qZ">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#EgoData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Quaternion that transforms from IMU coordinates to a fixed reference frame. The yaw of this reference frame is arbitrary, determined by the IMU. However, the x-y plane of the reference frame is perpendicular to gravity, and z points up.</synergies:description>
        <rdfs:label>qZ</rdfs:label>
    </owl:DatatypeProperty>
    


