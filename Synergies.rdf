        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Rear right brake speed in revolutions per minute.</synergies:description>
        <rdfs:label>rear_right_rpm</rdfs:label>
    </owl:DatatypeProperty>
    


