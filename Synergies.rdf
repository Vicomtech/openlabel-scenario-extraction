    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#segment_lengthX -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#segment_lengthX">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#LANE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>TODO: Investigate how we are going to express the point3D without having to create three different attributes. Could we work with arrays? (See what would be better for SPRAQL)</rdfs:comment>
        <rdfs:label>segment_lengthX</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#segment_lengthY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#segment_lengthY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#LANE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>segment_lengthY</rdfs:label>
    </owl:DatatypeProperty>
    


