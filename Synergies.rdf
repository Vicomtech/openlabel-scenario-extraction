        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <synergies:description>Coasting throttle. Values in range [0, 100].</synergies:description>
        <rdfs:label>regen</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#requestedTorqueAfterProc -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#requestedTorqueAfterProc">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#EgoData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <synergies:description>Input torque requested in Newton meters at a resolution of 0.5. Values in range [-400, 1647], offset by -400.</synergies:description>
        <rdfs:label>requestedTorqueAfterProc</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#right_of_ego -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#right_of_ego">
