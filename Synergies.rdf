    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#rotation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#rotation">
        <rdfs:domain>
            <owl:Class>
