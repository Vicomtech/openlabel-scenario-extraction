        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#FrameData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>rotation_rateY</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#rotation_rateZ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#rotation_rateZ">
