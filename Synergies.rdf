        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#EgoData"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment>Vehicle speed in km/h. Values in range [0, 60]. For a higher sampling rate refer to the pose.vel message.</rdfs:comment>
        <rdfs:label>odom_speed</rdfs:label>
    </owl:DatatypeProperty>
    


