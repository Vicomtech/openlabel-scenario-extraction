        <rdfs:label>start_poseX</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/vicomtech/ontologies/synergies#start_poseY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/vicomtech/ontologies/synergies#start_poseY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/vicomtech/ontologies/synergies#LANE"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:label>start_poseY</rdfs:label>
